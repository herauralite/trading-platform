{
  "manifest_version": 3,
  "name": "TaliTrade Bridge",
  "version": "0.1.0",
  "description": "Extension-first execution bridge for TaliTrade.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://api.talitrade.com/*", "http://localhost:8000/*", "<all_urls>"],
  "background": { "service_worker": "src/background/serviceWorker.js", "type": "module" },
  "action": { "default_popup": "src/popup/popup.html" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/bootstrap.js"],
      "run_at": "document_idle"
    }
  ]
}
